<!-- ==========================================
     HERO
========================================== -->
<section class="hero" id="home">
  <div class="hero-bg"></div>
  <div class="hero-city-img"></div>

  <!-- Lightning bolt SVG -->
  <div class="lightning">
    <svg width="80" height="120" viewBox="0 0 80 120" fill="none">
      <path d="M50 0L10 65h28L18 120l52-75H42L50 0z" fill="#ff89ab"/>
    </svg>
  </div>

  <!-- Hero content -->
  <div class="hero-content container">
    <div class="hero-sticker-wrap reveal">
      <span class="sticker sticker-lime sticker-rotate">🔥 Vibe Check Factory</span>
    </div>
    <div class="hero-headline reveal reveal-delay-1">
      <span class="display-xl">RECLAIM</span>
      <span class="display-xl line-italic">YOUR</span>
      <span class="display-xl">PLEASURE</span>
    </div>
    <p class="hero-sub reveal reveal-delay-2">
      We're here to burn the rulebook on wellness. No more clinical jargon, no more "guilty" pleasures. Just pure, unadulterated vibes.
    </p>
    <div class="hero-cta-wrap reveal reveal-delay-3">
      <a href="#products" class="btn btn-primary">Shop the Pulse</a>
      <span class="stay-loud-badge">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" fill="currentColor"/></svg>
        Stay Loud.
      </span>
    </div>
  </div>
  <div class="hero-scroll-hint">Scroll</div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "settings": []
}
{% endschema %}
