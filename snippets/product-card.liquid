<div class="product-card reveal">
  <div class="product-img-wrap">
    <div class="product-img-placeholder">{{ emoji | default: '🛍️' }}</div>
    {% if badge %}
      <span class="product-badge"><span class="sticker {{ badge_class | default: 'sticker-pink sticker-rotate' }}">{{ badge }}</span></span>
    {% endif %}
  </div>
  <div class="product-info">
    <p class="product-name">{{ title }}</p>
    {% render 'price', price: price, original_price: original_price %}
  </div>
  <button class="product-add-btn" onclick="addToCart({id:'{{ id }}',name:'{{ title }}',price:{{ price }},emoji:'{{ emoji | default: '🛍️' }}'})" aria-label="Add to cart">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M12 5v14M5 12h14" stroke="#0e0e0e" stroke-width="2" stroke-linecap="round"/></svg>
  </button>
</div>
